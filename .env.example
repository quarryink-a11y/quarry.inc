# ─────────────────────────────────────────────
# apps/server — NestJS backend
# ─────────────────────────────────────────────

# Database
DATABASE_URL=postgresql://user:password@localhost:5434/quarry?schema=public

# Server
PORT=4000

# JWT
JWT_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# CORS — comma-separated allowed origins (production only)
ALLOWED_ORIGINS=https://quarry.ink,https://www.quarry.ink

# Platform domain for multi-tenant slug routing
PLATFORM_BASE_DOMAIN=quarry.ink

# Cloudinary (media uploads)
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_RESTRICTED_KEY=rk_live_...
STRIPE_PRICE_BASIC=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Google OAuth (server-side)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# SMTP (transactional email)
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=

# Frontend URLs (for redirects, email links)
QUARRY_INC_FRONTEND_URL=http://localhost:3000


# ─────────────────────────────────────────────
# apps/company — Next.js company site (port 3000)
# ─────────────────────────────────────────────

NEXT_PUBLIC_API_URL=http://localhost:4000
BACKEND_URL=http://localhost:4000

NEXT_PUBLIC_PLATFORM_BASE_DOMAIN=http://localhost:3333

# Google OAuth (client-side)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Stripe (publishable key only)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...


# ─────────────────────────────────────────────
# apps/templates — Next.js multi-tenant app (port 3333)
# ─────────────────────────────────────────────

NEXT_PUBLIC_API_URL=http://localhost:4000
BACKEND_URL=http://localhost:4000

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
