{
    "name": "@quarry/server",
    "version": "0.0.1",
    "description": "",
    "author": "",
    "private": true,
    "license": "UNLICENSED",
    "scripts": {
        "build": "NODE_ENV=production nest build",
        "dev": "NODE_ENV=development nest start --watch",
        "format": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\"",
        "format:fix": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
        "start": "nest start",
        "start:dev": "NODE_ENV=development nest start --watch",
        "start:dev:swc": "nest start --watch -- -b swc",
        "start:debug": "nest start --debug --watch",
        "start:prod": "node dist/main",
        "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
        "lint:fix": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
        "typecheck": "tsc --noEmit",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:cov": "jest --coverage",
        "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
        "test:e2e": "jest --config ./test/jest-e2e.json",
        "prisma:dev:migrate": "npx prisma migrate dev",
        "prisma:migrate:deploy": "npx prisma migrate deploy",
        "prisma:seed": "npx prisma db seed",
        "prisma:generate": "npx prisma generate",
        "prisma:studio": "npx prisma studio",
        "prisma:clear-generated": "rm -rf ./generated",
        "prisma:push": "npx prisma db push",
        "prisma:clear-table": "npx prisma db push --force-reset",
        "prisma:pretty": "npx prisma format",
        "clear": "rm -rf dist node_modules .eslintcache coverage package-lock.json",
        "docker:stop": "docker stop server-dev-tattoo-app-1",
        "start:docker-prisma": "docker start server-dev-tattoo-app-1 && npx prisma studio"
    },
    "dependencies": {
        "@nestjs-modules/mailer": "^2.0.2",
        "@nestjs/axios": "^4.0.0",
        "@nestjs/cache-manager": "^3.1.0",
        "@nestjs/common": "^11.0.1",
        "@nestjs/config": "^4.0.2",
        "@nestjs/core": "^11.0.1",
        "@nestjs/jwt": "^11.0.0",
        "@nestjs/mapped-types": "*",
        "@nestjs/passport": "^11.0.5",
        "@nestjs/platform-express": "^11.0.1",
        "@nestjs/schedule": "^6.1.1",
        "@nestjs/swagger": "^11.2.6",
        "@prisma/adapter-pg": "^7.4.0",
        "@prisma/client": "^7.4.0",
        "bcrypt": "^6.0.0",
        "cache-manager": "^7.2.8",
        "cloudinary": "^2.7.0",
        "cookie-parser": "^1.4.7",
        "csrf-csrf": "^4.0.3",
        "google-auth-library": "^10.6.1",
        "handlebars": "^4.7.8",
        "jose": "^6.2.1",
        "nodemailer": "^8.0.2",
        "passport": "^0.7.0",
        "passport-jwt": "^4.0.1",
        "reflect-metadata": "^0.2.2",
        "rxjs": "^7.8.1",
        "stripe": "^20.4.1",
        "swagger-ui-express": "^5.0.1",
        "tsx": "^4.21.0"
    },
    "devDependencies": {
        "@eslint/eslintrc": "^3.2.0",
        "@eslint/js": "^9.18.0",
        "@nestjs/cli": "^11.0.0",
        "@nestjs/schematics": "^11.0.0",
        "@nestjs/testing": "^11.0.1",
        "@swc/cli": "^0.6.0",
        "@swc/core": "^1.10.7",
        "@types/bcrypt": "^5.0.2",
        "@types/cookie-parser": "^1.4.10",
        "@types/express": "^5.0.6",
        "@types/jest": "^29.5.14",
        "@types/multer": "^1.4.13",
        "@types/passport-jwt": "^4.0.1",
        "@types/supertest": "^6.0.2",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.14.2",
        "dotenv": "^17.3.1",
        "eslint": "^9.18.0",
        "eslint-config-prettier": "^10.0.1",
        "eslint-plugin-prettier": "^5.2.2",
        "eslint-plugin-simple-import-sort": "^12.1.1",
        "globals": "^16.0.0",
        "jest": "^29.7.0",
        "prisma": "^7.4.0",
        "source-map-support": "^0.5.21",
        "supertest": "^7.0.0",
        "ts-jest": "^29.2.5",
        "ts-loader": "^9.5.2",
        "ts-node": "^10.9.2",
        "tsconfig-paths": "^4.2.0",
        "typescript-eslint": "^8.20.0"
    },
    "jest": {
        "moduleFileExtensions": [
            "js",
            "json",
            "ts"
        ],
        "rootDir": "src",
        "testRegex": ".*\\.spec\\.ts$",
        "transform": {
            "^.+\\.(t|j)s$": "ts-jest"
        },
        "collectCoverageFrom": [
            "**/*.(t|j)s"
        ],
        "coverageDirectory": "../coverage",
        "testEnvironment": "node"
    }
}
