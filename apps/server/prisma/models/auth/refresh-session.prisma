model RefreshSession {
  id         String   @id @default(cuid())
  user_id    String
  token_hash String   @unique
  expires_at DateTime
  revoked_at DateTime?
  created_at DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@map("refresh_sessions")
}