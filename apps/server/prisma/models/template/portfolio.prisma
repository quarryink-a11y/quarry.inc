model Portfolio {
    id        String    @id @default(cuid())
    site_id        String

    price     Decimal? @db.Decimal(10, 2)
    currency  Currency?
    size      Float?
    size_unit SizeUnit?
    image_url       String
    image_public_id String?
    type            ContentType @default(DRAFT)

    created_at DateTime @default(now())
    updated_at DateTime @updatedAt

    site Site @relation(fields: [site_id], references: [id], onDelete: Cascade)

    @@index([id])
    @@index([created_at])
    @@index([updated_at])
    @@index([currency])
    @@index([size_unit])
    @@index([price])
    @@index([site_id, type])
    @@map("portfolios")
}
