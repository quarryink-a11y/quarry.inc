{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "outDir": "./dist",
    "baseUrl": ".",
    "incremental": true,
    "strictPropertyInitialization": false,
    "noFallthroughCasesInSwitch": true,
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": [
    "src/**/*",
    "prisma/**/*",
    "./global.d.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "DEPRECATED"
  ]
}